# Core
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./data/app.db

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4
ORG_ID=
SYSTEM_PROMPT=You are a helpful, concise email assistant.
MAX_TOKENS_WINDOW=10000
MAX_COMPLETION_TOKENS=512

# Inbound Webhook Security
INBOUND_API_TOKEN=replace-with-a-random-webhook-token

# SMTP Outbound
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey-or-username
SMTP_PASSWORD=secret
SMTP_USE_TLS=true
SMTP_USE_SSL=false
FROM_FALLBACK_EMAIL=noreply@example.com

# App URLs
APP_BASE_URL=http://127.0.0.1:8000

# Delegation
DELEGATED_EMAIL=
